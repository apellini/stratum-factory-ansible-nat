[Unit]
Description=STRATUM internal-subnet static route ({{ nat_internal_cidr }} via {{ nat_internal_interface }})
Documentation=https://github.com/apellini/stratum-factory-ansible-nat
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/sbin/ip route replace {{ nat_internal_cidr }} dev {{ nat_internal_interface }}{{ (nat_internal_ip != '') | ternary(' src ' ~ nat_internal_ip, '') }}

[Install]
WantedBy=multi-user.target
